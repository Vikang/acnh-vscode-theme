{
  "name": "acnh-vscode-theme",
  "displayName": "Animal Crossing New Horizons Theme",
  "description": "A cozy theme for VS Code inspired by Animal Crossing: New Horizons. Three variants — Tom Nook (light), Blathers (dark neon), and Brewster (dark cozy) — with warm cream, soft green, and deep blue tones for a relaxing coding experience.",
  "version": "0.2.0",
  "publisher": "vikang",
  "license": "Apache-2.0",
  "icon": "acnh_leaf.png",
  "keywords": [
    "animal crossing",
    "light theme",
    "dark theme",
    "pastel",
    "cozy",
    "nintendo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Vikang/acnh-vscode-theme"
  },
  "homepage": "https://github.com/Vikang/acnh-vscode-theme#readme",
  "bugs": {
    "url": "https://github.com/Vikang/acnh-vscode-theme/issues"
  },
  "galleryBanner": {
    "color": "#EEE9CA",
    "theme": "light"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Themes"],
  "main": "./src/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "themes": [
      {
        "label": "ACNH New Horizons — Tom Nook",
        "uiTheme": "vs",
        "path": "./themes/acnh-new-horizons-light-color-theme.json"
      },
      {
        "label": "ACNH New Horizons — Blathers",
        "uiTheme": "vs-dark",
        "path": "./themes/acnh-new-horizons-dark-color-theme.json"
      },
      {
        "label": "ACNH New Horizons — Brewster",
        "uiTheme": "vs-dark",
        "path": "./themes/acnh-new-horizons-dark-cozy-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "acnh.enableFont",
        "title": "ACNH: Enable Roboto Font"
      },
      {
        "command": "acnh.disableFont",
        "title": "ACNH: Disable Roboto Font"
      },
      {
        "command": "acnh.enableCursor",
        "title": "ACNH: Enable Animal Crossing Cursors"
      },
      {
        "command": "acnh.disableCursor",
        "title": "ACNH: Disable Animal Crossing Cursors"
      }
    ]
  }
}
